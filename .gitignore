.env
data

# Built artifacts — pre-built для sm_120a (RTX PRO 6000 Blackwell).
# Включены в репо чтобы пользователи могли запускать сразу без сборки.
# Для других архитектур — пересобрать через runs/_build_*.sh скрипты.
#libs/*.so       — commit (sm_120a pre-built libs)
#fa_v*           — commit (sm_120a pre-built bench binaries)
#runs/fa_*       — commit

# НЕ комитим: профили NCu (330 MB), интермедиаты, кеши.
*.ncu-rep
runs/*.cubin
/tmp/goml-*

./data/arxiv_150.txt
./data/corpus_multi.txt
./data/wiki_az.txt
./data/wiki_tr.txt
./data/trwiki-latest-pages-articles.xml.bz2
./data/ruwiki-latest-pages-articles.xml.bz2
./data/wiki_ru.txt
./data/wiki_en_200.txt
./data/arxiv.txt
./data/azwiki-latest-pages-articles.xml.bz2
./data/en_combined.txt
./data/wiki_en_old.txt
./runs1/fp8_profile.ncu-rep

# R03a-era additions (2026-07-18)
# NCu кэш и тяжёлые артефакты
/ncu_home/
# Тестовые release-clones + промежуточные release-снапшоты
/release_v0.2.0/
/release_verify_clone/
# Bench-логи champion-run'ов
champion_*.log
# libs/: временные Makefile'и per-бенч, build-логи, SASS/PTX-дампы, snapshot'ы .cu
libs/Makefile.*
libs/*_build.log
libs/*.log
libs/*.sass
libs/*.ptx
libs/*.cu.*
# runs/: NCu-логи, sass/ptx-дампы, json-стата, txt-выгрузки
runs/*.json
runs/*.sass
runs/*.ptx
runs/*.txt
runs/*.log
runs/*_raw.*
